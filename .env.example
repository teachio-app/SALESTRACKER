# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # server-only, never expose to client

# Zoho IMAP (use an app-specific password, not your login password)
IMAP_HOST=imappro.zoho.eu
IMAP_PORT=993
IMAP_USER=petr.pech@thevortex.beauty
IMAP_PASSWORD=your-zoho-app-password

# Discord (notification only)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_PAYMENT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/zzz   # payout pings

# Dashboard login (HTTP Basic Auth — gates the dashboard + /api/tickets)
APP_USER=admin
APP_PASSWORD=pick-something

# Cron protection — Vercel auto-sends this as a Bearer header on cron runs;
# the external pinger must send the same. Does NOT gate the human login.
CRON_SECRET=some-long-random-string
